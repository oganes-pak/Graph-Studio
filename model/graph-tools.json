{
  "version": "graph-studio-tools/3",
  "tools": [
    {
      "name": "get_project",
      "title": "Получить проект",
      "description": "Возвращает тип диаграммы, данные, настройки и состояние.",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "get_info_templates",
      "title": "Получить шаблоны инфоблоков",
      "description": "Возвращает каталог машинно-понятных типов информационных секций и примеры полей.",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "replace_graph",
      "title": "Заменить проект",
      "description": "Мягко нормализует и полностью заменяет данные диаграммы.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "diagramType": {
            "type": "string",
            "enum": [
              "info",
              "fishbone",
              "flowchart",
              "tree",
              "force",
              "sankey",
              "network",
              "radar",
              "bubble",
              "mindmap",
              "decision"
            ]
          },
          "nodes": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "connections": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "links": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "chart": {
            "type": "object"
          },
          "document": {
            "type": "object"
          }
        },
        "required": [],
        "additionalProperties": false
      }
    },
    {
      "name": "set_diagram_type",
      "title": "Выбрать тип диаграммы",
      "description": "Переключает тип диаграммы и интерпретирует текущие данные под выбранное представление.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "diagramType": {
            "type": "string",
            "enum": [
              "info",
              "fishbone",
              "flowchart",
              "tree",
              "force",
              "sankey",
              "network",
              "radar",
              "bubble",
              "mindmap",
              "decision"
            ]
          }
        },
        "required": [
          "diagramType"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "set_chart_data",
      "title": "Задать данные диаграммы",
      "description": "Заменяет chart.metrics и chart.series, используемые радаром.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "chart": {
            "type": "object"
          }
        },
        "required": [
          "chart"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "set_document_data",
      "title": "Задать информационные блоки",
      "description": "Заменяет документ информационной панели: секции, рейтинги, карточки и таблицы.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "document": {
            "type": "object"
          }
        },
        "required": [
          "document"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "add_node",
      "title": "Добавить узел",
      "description": "Добавляет один узел с уникальным id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-zА-Яа-яЁё0-9_-]+$",
            "description": "Короткий стабильный идентификатор без пробелов."
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string"
          },
          "shape": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          },
          "size": {
            "type": "number",
            "minimum": 1,
            "maximum": 200
          },
          "opacity": {
            "type": "number",
            "minimum": 0.05,
            "maximum": 1
          },
          "x": {
            "type": "number"
          },
          "y": {
            "type": "number"
          },
          "value": {
            "type": "number",
            "minimum": 0
          },
          "column": {
            "type": "number",
            "minimum": 0
          }
        },
        "required": [
          "id",
          "name"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "change_node",
      "title": "Изменить узел",
      "description": "Изменяет свойства существующего узла.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-zА-Яа-яЁё0-9_-]+$",
            "description": "Короткий стабильный идентификатор без пробелов."
          },
          "changes": {
            "type": "object",
            "minProperties": 1
          }
        },
        "required": [
          "id",
          "changes"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "delete_node",
      "title": "Удалить узел",
      "description": "Удаляет узел и его связи.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-zА-Яа-яЁё0-9_-]+$",
            "description": "Короткий стабильный идентификатор без пробелов."
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "add_connection",
      "title": "Добавить связь",
      "description": "Соединяет два существующих узла. Между одной парой разрешена только одна связь.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-zА-Яа-яЁё0-9_-]+$",
            "description": "Короткий стабильный идентификатор без пробелов."
          },
          "to": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-zА-Яа-яЁё0-9_-]+$",
            "description": "Короткий стабильный идентификатор без пробелов."
          },
          "label": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          },
          "width": {
            "type": "number",
            "minimum": 0.5,
            "maximum": 50
          },
          "value": {
            "type": "number",
            "minimum": 0
          }
        },
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "change_connection",
      "title": "Изменить связь",
      "description": "Изменяет одну связь между указанными узлами.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-zА-Яа-яЁё0-9_-]+$",
            "description": "Короткий стабильный идентификатор без пробелов."
          },
          "to": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-zА-Яа-яЁё0-9_-]+$",
            "description": "Короткий стабильный идентификатор без пробелов."
          },
          "changes": {
            "type": "object",
            "minProperties": 1
          }
        },
        "required": [
          "from",
          "to",
          "changes"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "delete_connection",
      "title": "Удалить связь",
      "description": "Удаляет одну связь между указанными узлами.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "from": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-zА-Яа-яЁё0-9_-]+$",
            "description": "Короткий стабильный идентификатор без пробелов."
          },
          "to": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-zА-Яа-яЁё0-9_-]+$",
            "description": "Короткий стабильный идентификатор без пробелов."
          }
        },
        "required": [
          "from",
          "to"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "set_layout",
      "title": "Выбрать сетевую раскладку",
      "description": "Для сетевой диаграммы выбирает паутину или соты.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "layout": {
            "type": "string",
            "enum": [
              "planetary",
              "hex"
            ]
          }
        },
        "required": [
          "layout"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "change_view",
      "title": "Изменить внешний вид",
      "description": "Применяет частичные настройки отображения.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "changes": {
            "type": "object",
            "minProperties": 1
          }
        },
        "required": [
          "changes"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "set_read_only",
      "title": "Режим только просмотра",
      "description": "Включает или выключает запрет редактирования.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean"
          }
        },
        "required": [
          "enabled"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "add_legend_item",
      "title": "Добавить пункт легенды",
      "description": "Добавляет одно обозначение.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-zА-Яа-яЁё0-9_-]+$",
            "description": "Короткий стабильный идентификатор без пробелов."
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          },
          "shape": {
            "type": "string",
            "enum": [
              "circle",
              "square",
              "diamond"
            ]
          }
        },
        "required": [
          "id",
          "label",
          "color"
        ],
        "additionalProperties": false
      }
    },
    {
      "name": "delete_legend_item",
      "title": "Удалить пункт легенды",
      "description": "Удаляет обозначение по id.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-zА-Яа-яЁё0-9_-]+$",
            "description": "Короткий стабильный идентификатор без пробелов."
          }
        },
        "required": [
          "id"
        ],
        "additionalProperties": false
      }
    }
  ]
}
